{
  "name": "article-reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "npm run build && wrangler pages deploy out --project-name=article-reader",
    "wrangler:dev": "wrangler dev",
    "wrangler:deploy": "wrangler deploy",
    "db:create": "wrangler d1 create article-reader-db",
    "db:migrate": "wrangler d1 migrations apply article-reader-db",
    "db:migrate:local": "wrangler d1 migrations apply article-reader-db --local",
    "db:query": "wrangler d1 execute article-reader-db --command",
    "db:query:local": "wrangler d1 execute article-reader-db --local --command"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@tailwindcss/typography": "^0.5.19",
    "lz-string": "^1.5.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260131.0",
    "@tailwindcss/postcss": "^4",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.61.1"
  }
}
